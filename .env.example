# Nalana Dataset Pipeline — API Keys
# Copy to .env and fill in. Then run: source .env before any script.

# ── YouTube Data API v3 ───────────────────────────────────────────────────────
# Free. Get at: https://console.cloud.google.com → APIs → YouTube Data API v3
# Quota: 10,000 units/day (search = 100 units, playlist crawl = 1 unit/50 videos)
YOUTUBE_API_KEY=

# ── Anthropic / Claude ────────────────────────────────────────────────────────
# For synthesis fallback + form analysis via claude-opus-4-6 (vision)
ANTHROPIC_API_KEY=

# ── Sketchfab ─────────────────────────────────────────────────────────────────
# Free account. Token at: https://sketchfab.com/settings/password
# 4M+ CC-licensed models. Download as GLB/GLTF.
SKETCHFAB_API_TOKEN=

# ── Adobe Substance 3D ────────────────────────────────────────────────────────
# 6,000+ production 3D models (FBX/GLB) + unlimited PBR materials (SBSAR)
# Apply at: https://developer.adobe.com/firefly-services/docs/s3dapi/
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=
ADOBE_ORG_ID=

# ── Hugging Face ──────────────────────────────────────────────────────────────
# For downloading Objaverse, model weights (Qwen2-VL), datasets
# Free at: https://huggingface.co/settings/tokens
HF_TOKEN=

# ── Thingiverse ───────────────────────────────────────────────────────────────
# 2M+ printable 3D models (STL/OBJ). Free account.
# App token at: https://www.thingiverse.com/apps/create
THINGIVERSE_TOKEN=

# ── Weights & Biases ──────────────────────────────────────────────────────────
# Training monitoring. Free at: https://wandb.ai
WANDB_API_KEY=
WANDB_PROJECT=nalana-v1

# ── Azure ─────────────────────────────────────────────────────────────────────
# $25k credits. Used for deployment, blob storage, container registry.
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=nalana
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CONTAINER_REGISTRY=

# ── vLLM (synthesis servers on A6000 cluster) ─────────────────────────────────
# These are set by scripts/start_vllm.sh — change host if on multi-node
VLLM_API_KEY=nalana
VLLM_TEXT_URL=http://localhost:8001
VLLM_TEXT_URL_2=http://localhost:8002
VLLM_VISION_URL=http://localhost:8003
VLLM_VISION_URL_2=http://localhost:8004

# ── Blender ───────────────────────────────────────────────────────────────────
# Path to Blender executable on the cluster
# Linux (Azure): /usr/bin/blender  or  /opt/blender/blender
# macOS: /Applications/Blender.app/Contents/MacOS/Blender
BLENDER_PATH=/usr/bin/blender

# ── Polyhaven ─────────────────────────────────────────────────────────────────
# NO API KEY NEEDED. CC0 free. Direct CDN download.
POLYHAVEN_RESOLUTION=2k   # 1k, 2k, 4k, 8k

# ── Smithsonian 3D ────────────────────────────────────────────────────────────
# NO API KEY NEEDED. Public domain 3D scans.
# https://3d.si.edu/

# ── NIH 3D Print Exchange ──────────────────────────────────────────────────────
# NO API KEY NEEDED. Public domain scientific models.
# https://3dprint.nih.gov/
